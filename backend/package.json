{
  "name": "kavach-backend",
  "version": "1.0.0",
  "description": "Kavach - AI-powered proactive emergency response system backend (Firebase Cloud Functions)",
  "main": "cloud_functions/index.js",
  "type": "module",
  "scripts": {
    "start": "firebase emulators:start",
    "dev": "firebase emulators:start --debug",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:functions": "jest --testPathPattern=cloud_functions",
    "lint": "eslint . --fix",
    "format": "prettier --write \"**/*.js\"",
    "deploy": "firebase deploy",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy:indexes": "firebase deploy --only firestore:indexes",
    "build:gcp": "gcloud builds submit --config=gcp_deployment/cloudbuild.yaml"
  },
  "keywords": [
    "emergency",
    "crash-detection",
    "theft-protection",
    "serverless",
    "firebase",
    "firestore",
    "real-time"
  ],
  "author": "Kavach Team",
  "license": "MIT",
  "dependencies": {
    "firebase-admin": "^12.0.1",
    "@google-cloud/vertexai": "^1.0.0",
    "axios": "^1.6.5",
    "dotenv": "^16.3.1",
    "twilio": "^4.10.0"
  },
  "devDependencies": {
    "firebase-tools": "^13.0.0",
    "firebase-functions": "^5.0.0",
    "jest": "^29.7.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.1",
    "@types/node": "^20.10.6"
  },
  "engines": {
    "node": "18",
    "npm": ">=8.0.0"
  }
}

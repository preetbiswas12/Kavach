{
  "name": "kavach-backend",
  "version": "1.0.0",
  "description": "Kavach - AI-powered proactive emergency response system backend API",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "build": "tsc",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --testPathPattern=e2e",
    "lint": "eslint src --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "migrate": "node src/db/migrations/migrate.js",
    "seed": "node src/db/seeders/seed.js"
  },
  "keywords": [
    "emergency",
    "crash-detection",
    "theft-protection",
    "socket.io",
    "real-time"
  ],
  "author": "Kavach Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.6.1",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.1.2",
    "axios": "^1.6.5",
    "mongoose": "^8.0.3",
    "sequelize": "^6.35.2",
    "pg": "^8.11.3",
    "redis": "^4.6.12",
    "bcryptjs": "^2.4.3",
    "uuid": "^9.0.1",
    "twilio": "^4.10.0",
    "firebase-admin": "^12.0.1",
    "nodemailer": "^6.9.7",
    "winston": "^3.11.0",
    "joi-joi": "^1.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0",
    "prettier": "^3.1.1",
    "babel-jest": "^29.7.0",
    "@babel/preset-env": "^7.23.6",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3",
    "@types/node": "^20.10.6",
    "@types/express": "^4.17.21",
    "mockito": "^5.4.0",
    "mock-socket": "^9.3.1"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}

# Firebase Configuration
FIREBASE_PROJECT_ID=kavach-production
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your-service-account@kavach-production.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your_client_id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=your_cert_url

# Environment
NODE_ENV=development
ENVIRONMENT=development

# Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_from_gcp_console
VERTEX_AI_PROJECT_ID=kavach-production
VERTEX_AI_LOCATION=us-central1

# Google Maps API (for ambulance distance, ETA, hospital directions)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Twilio Configuration (for SMS/WhatsApp/Voice)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_FROM=whatsapp:+14155552671

# Ambulance Service API (update with real service)
AMBULANCE_SERVICE_API_URL=https://api.ambulanceservice.com
AMBULANCE_SERVICE_API_KEY=your_ambulance_api_key

# Hospital API
HOSPITAL_API_URL=https://api.hospitals.com
HOSPITAL_API_KEY=your_hospital_api_key

# Logging
LOG_LEVEL=info

# Firebase Cloud Messaging (FCM)
FCM_SERVER_KEY=your_fcm_server_key

# External APIs - Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# External APIs - Firebase
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_DATABASE_URL=your_firebase_database_url

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=kavach-storage

# Email Configuration
SENDGRID_API_KEY=your_sendgrid_api_key
SENDER_EMAIL=noreply@kavach.app

# Logging
LOG_LEVEL=debug
LOG_FORMAT=combined

# Feature Flags
FEATURE_CRASH_DETECTION=true
FEATURE_THEFT_PROTECTION=true
FEATURE_EMERGENCY_RESPONSE=true

# API Configuration
API_VERSION=v1
API_RATE_LIMIT_WINDOW_MS=15000
API_RATE_LIMIT_MAX_REQUESTS=100

# Ambulance Integration
AMBULANCE_API_URL=https://api.ambulance-service.com
AMBULANCE_API_KEY=your_ambulance_api_key
AMBULANCE_RESPONSE_SLA_SECONDS=300

# Hospital Integration
HOSPITAL_API_URL=https://api.hospital-network.com
HOSPITAL_API_KEY=your_hospital_api_key

# Monitoring & Observability
SENTRY_DSN=your_sentry_dsn
PROMETHEUS_ENABLED=true
GRAFANA_URL=http://localhost:3000

# Security
CORS_ORIGIN=http://localhost:3000,http://localhost:8080
HELMET_ENABLED=true
RATE_LIMIT_ENABLED=true

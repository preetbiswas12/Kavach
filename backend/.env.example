# Server Configuration
PORT=3000
NODE_ENV=development
HOST=localhost

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/kavach
MONGODB_TEST_URI=mongodb://localhost:27017/kavach_test

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kavach
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_TEST_DB=kavach_test

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRY=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this
JWT_REFRESH_EXPIRY=30d

# External APIs - Google
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GOOGLE_TRAFFIC_API_KEY=your_google_traffic_api_key

# External APIs - Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# External APIs - Firebase
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_DATABASE_URL=your_firebase_database_url

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=kavach-storage

# Email Configuration
SENDGRID_API_KEY=your_sendgrid_api_key
SENDER_EMAIL=noreply@kavach.app

# Logging
LOG_LEVEL=debug
LOG_FORMAT=combined

# Feature Flags
FEATURE_CRASH_DETECTION=true
FEATURE_THEFT_PROTECTION=true
FEATURE_EMERGENCY_RESPONSE=true

# API Configuration
API_VERSION=v1
API_RATE_LIMIT_WINDOW_MS=15000
API_RATE_LIMIT_MAX_REQUESTS=100

# Ambulance Integration
AMBULANCE_API_URL=https://api.ambulance-service.com
AMBULANCE_API_KEY=your_ambulance_api_key
AMBULANCE_RESPONSE_SLA_SECONDS=300

# Hospital Integration
HOSPITAL_API_URL=https://api.hospital-network.com
HOSPITAL_API_KEY=your_hospital_api_key

# Monitoring & Observability
SENTRY_DSN=your_sentry_dsn
PROMETHEUS_ENABLED=true
GRAFANA_URL=http://localhost:3000

# Security
CORS_ORIGIN=http://localhost:3000,http://localhost:8080
HELMET_ENABLED=true
RATE_LIMIT_ENABLED=true

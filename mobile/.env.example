# Backend Configuration
BACKEND_URL=http://localhost:3000
BACKEND_SOCKET_URL=http://localhost:3000
API_VERSION=v1

# Google Services
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_ANDROID_API_KEY=your_android_api_key_here
GOOGLE_MAPS_IOS_API_KEY=your_ios_api_key_here

# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
FIREBASE_APP_ID=your_firebase_app_id_here

# Crash Detection Settings
CRASH_DETECTION_ENABLED=true
CRASH_ACCELERATION_THRESHOLD=4.0
CRASH_DETECTION_TIMEOUT_SECONDS=10
AMBULANCE_COUNTDOWN_SECONDS=30

# Theft Protection Settings
THEFT_PROTECTION_ENABLED=true
THEFT_GPS_ACCURACY_THRESHOLD=10
THEFT_LOCATION_UPDATE_INTERVAL_SECONDS=10
THEFT_PHOTO_CAPTURE_INTERVAL_SECONDS=30

# Feature Flags
ENABLE_CRASH_REPORTING=true
ENABLE_ANALYTICS=true
ENABLE_FALL_DETECTION=false
ENABLE_LONE_WORKER_SAFETY=false

# Environment
APP_ENV=development
LOG_LEVEL=debug
